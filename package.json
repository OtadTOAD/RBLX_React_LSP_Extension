{
  "name": "rblx-react-lsp",
  "displayName": "Roblox React LSP: Luau IntelliSense",
  "description": "IntelliSense and autocomplete for Roblox instances, properties, and events in React-Luau projects.",
  "version": "0.3.5",
  "keywords": [
    "Roblox",
    "Luau",
    "React",
    "IntelliSense",
    "Roact"
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage",
    "workspaceContains:/*.project.json"
  ],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/OtadTOAD/RBLX_React_LSP_Extension.git"
  },
  "publisher": "OtadTOAD",
  "contributes": {
    "commands": [
      {
        "title": "RBLX React: Generate and Cache API Metadata",
        "shortTitle": "Generate Metadata",
        "command": "rblx-react-lsp.genMetadata"
      },
      {
        "title": "RBLX React: Download and Prettify API as JSON",
        "shortTitle": "Generate JSON",
        "command": "rblx-react-lsp.readCache"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.97.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "electron": "^34.2.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}